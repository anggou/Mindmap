# ─────────────────────────────────────────────────────────────────
# .env.example  →  복사 후 .env 로 이름을 바꾸고 값을 채워주세요.
# 사용할 AI 모델의 API 키만 입력하면 됩니다.
# ─────────────────────────────────────────────────────────────────

# [Gemini] Google AI Studio에서 발급
# 발급 URL: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [GPT] OpenAI Platform에서 발급
# 발급 URL: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# [Claude] Anthropic Console에서 발급
# 발급 URL: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
